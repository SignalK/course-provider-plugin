{
    "name": "@signalk/course-provider",
    "version": "1.2.7",
    "description": "Course data provider plugin for SignalK Server.",
    "main": "plugin/index.js",
    "keywords": [
        "signalk-node-server-plugin",
        "signalk-category-utility",
        "signalk",
        "signalk-min-api-version:2"
    ],
    "repository": {
        "url": "git+https://github.com/SignalK/coursedata-provider-plugin.git",
        "type": "git"
    },
    "author": "AdrianP",
    "contributors": [
        {
            "name": "panaaj@hotmail.com"
        }
    ],
    "license": "Apache-2.0",
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "build-declaration": "tsc --declaration --allowJs false",
        "watch": "npm run build -- -w",
        "test": "vitest run",
        "start": "npm run build -- -w",
        "prepublishOnly": "tsc",
        "format": "prettier --write \"src/**/*.{ts,js}\" \"test/**/*.ts\"",
        "lint": "prettier --check \"src/**/*.{ts,js}\" \"test/**/*.ts\""
    },
    "dependencies": {
        "@signalk/server-api": "2.9.0",
        "rxjs": "^7.5.2"
    },
    "devDependencies": {
        "@types/baconjs": "^0.7.34",
        "@types/express": "^4.17.8",
        "@types/node": "^22.19.15",
        "@types/node-fetch": "^2.5.6",
        "prettier": "^2.6.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0"
    },
    "signalk-plugin-enabled-by-default": true
}
