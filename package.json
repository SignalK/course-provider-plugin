{
  "name": "@signalk/course-provider",
  "version": "1.2.7",
  "description": "Course data provider plugin for SignalK Server.",
  "main": "plugin/index.js",
  "types": "plugin/index.d.ts",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-utility",
    "signalk",
    "signalk-min-api-version:2"
  ],
  "repository": {
    "url": "git+https://github.com/SignalK/coursedata-provider-plugin.git",
    "type": "git"
  },
  "author": "AdrianP",
  "contributors": [
    {
      "name": "panaaj@hotmail.com"
    }
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "plugin",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf plugin",
    "prebuild": "npm run clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "mutation": "stryker run",
    "prettier:check": "prettier --check .",
    "prettier": "prettier --write .",
    "format": "npm run prettier",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@signalk/server-api": "^2.24.0",
    "rxjs": "^7.5.2"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/express": "^4.17.8",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^4.1.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0"
  },
  "signalk-plugin-enabled-by-default": true
}
